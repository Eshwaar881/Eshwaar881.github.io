<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Nambala Eshwaar · AI & Web Developer</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#09090b;
  --bg2:#111113;
  --bg3:#18181b;
  --card:#1c1c1f;
  --border:#2a2a2e;
  --border2:#363639;
  --text:#f4f4f5;
  --muted:#a1a1aa;
  --faint:#52525b;
  --lime:#c8f135;
  --lime-dim:#9cbf1c;
  --lime-glow:rgba(200,241,53,0.12);
  --purple:#a78bfa;
  --purple-glow:rgba(167,139,250,0.1);
  --orange:#fb923c;
}
html{scroll-behavior:smooth}
body{font-family:'Cabinet Grotesk',sans-serif;background:var(--bg);color:var(--text);line-height:1.7;overflow-x:hidden}

/* CURSOR DOT */
.cursor{width:8px;height:8px;background:var(--lime);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transition:transform .15s ease;mix-blend-mode:difference}

/* NAV */
nav{
  position:sticky;top:0;z-index:100;
  background:rgba(9,9,11,0.85);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;height:64px;
}
.nav-logo{font-family:'Clash Display',sans-serif;font-weight:700;font-size:1.1rem;color:var(--lime);letter-spacing:-0.5px}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{font-size:0.8rem;font-weight:500;color:var(--muted);text-decoration:none;letter-spacing:0.08em;text-transform:uppercase;transition:color .2s}
.nav-links a:hover{color:var(--lime)}
.nav-cta{background:var(--lime);color:#09090b;font-size:0.8rem;font-weight:700;padding:8px 20px;border-radius:100px;text-decoration:none;letter-spacing:0.04em;transition:opacity .2s}
.nav-cta:hover{opacity:0.85}

/* HERO */
.hero{
  min-height:100vh;display:flex;flex-direction:column;justify-content:center;
  max-width:1300px;margin:0 auto;padding:6rem 3rem 4rem;
  position:relative;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:0.75rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--lime);margin-bottom:2rem;
}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--lime);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

.hero h1{
  font-family:'Clash Display',sans-serif;
  font-size:clamp(4rem,9vw,10rem);
  font-weight:700;line-height:0.9;
  letter-spacing:-4px;
  color:var(--text);
  margin-bottom:2.5rem;
}
.hero h1 .outline{
  -webkit-text-stroke:1.5px var(--text);
  color:transparent;
}
.hero h1 .accent{color:var(--lime)}

.hero-bottom{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;margin-top:1rem}
.hero-desc{font-size:1rem;color:var(--muted);line-height:1.8;font-weight:300;max-width:440px}
.hero-meta{display:flex;flex-direction:column;gap:1rem;align-items:flex-end}
.hero-stat{text-align:right}
.hero-stat-num{font-family:'Clash Display',sans-serif;font-size:3rem;font-weight:700;color:var(--lime);line-height:1}
.hero-stat-label{font-size:0.75rem;color:var(--faint);letter-spacing:0.1em;text-transform:uppercase}
.hero-chips{display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:flex-end;margin-top:0.5rem}
.chip{
  font-size:0.75rem;font-weight:500;color:var(--muted);
  border:1px solid var(--border2);border-radius:100px;
  padding:5px 14px;background:var(--bg3);
}

/* MARQUEE */
.marquee-wrap{
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  overflow:hidden;padding:1rem 0;margin:4rem 0 0;background:var(--bg2);
}
.marquee-inner{display:flex;gap:4rem;animation:marquee 20s linear infinite;width:max-content}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.marquee-item{
  font-family:'Clash Display',sans-serif;font-size:0.85rem;font-weight:600;
  letter-spacing:0.15em;text-transform:uppercase;color:var(--faint);white-space:nowrap;
  display:flex;align-items:center;gap:1rem;
}
.marquee-item span{color:var(--lime);font-size:1.2rem}

/* SECTION BASE */
section{max-width:1300px;margin:0 auto;padding:8rem 3rem}
.s-eyebrow{font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--lime);font-weight:600;margin-bottom:1rem;display:flex;align-items:center;gap:0.75rem}
.s-eyebrow::before{content:'';width:32px;height:1px;background:var(--lime)}
.s-heading{
  font-family:'Clash Display',sans-serif;font-size:clamp(2.5rem,4vw,5rem);
  font-weight:700;letter-spacing:-2px;color:var(--text);line-height:1.0;
  margin-bottom:1.5rem;
}
.s-divider{border:none;border-top:1px solid var(--border);max-width:1300px;margin:0 auto}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;margin-top:4rem}
.about-text{font-size:1.05rem;color:var(--muted);line-height:1.9;font-weight:300}
.about-text p{margin-bottom:1.25rem}
.about-right{}
.cert-card{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:1.25rem 1.5rem;margin-bottom:0.75rem;display:flex;gap:1rem;align-items:flex-start;
  transition:border-color .2s,background .2s;
}
.cert-card:hover{border-color:var(--lime);background:var(--bg3)}
.cert-num{
  font-family:'Clash Display',sans-serif;font-size:1.5rem;font-weight:700;
  color:var(--lime);line-height:1;flex-shrink:0;opacity:0.4;
}
.cert-title{font-size:0.9rem;font-weight:500;color:var(--text);margin-bottom:3px}
.cert-sub{font-size:0.8rem;color:var(--faint);line-height:1.5}

/* SKILLS */
.skills-bento{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-top:4rem}
.skill-tile{
  background:var(--card);border:1px solid var(--border);border-radius:20px;
  padding:1.75rem 1.5rem;transition:border-color .25s,transform .25s;
}
.skill-tile:hover{border-color:var(--lime);transform:translateY(-4px)}
.skill-tile.wide{grid-column:span 2}
.tile-icon{
  width:44px;height:44px;border-radius:12px;
  border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;
  font-size:20px;margin-bottom:1.25rem;background:var(--bg3);
}
.tile-cat{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--lime);font-weight:600;margin-bottom:0.4rem}
.tile-name{font-family:'Clash Display',sans-serif;font-size:1.05rem;font-weight:600;color:var(--text);margin-bottom:0.75rem}
.tag-row{display:flex;flex-wrap:wrap;gap:0.4rem}
.stag{
  font-size:0.72rem;font-weight:500;
  background:rgba(200,241,53,0.08);color:var(--lime-dim);
  border:1px solid rgba(200,241,53,0.2);border-radius:100px;padding:3px 11px;
}

/* PROJECTS */
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:4rem}
.proj-card{
  background:var(--card);border:1px solid var(--border);border-radius:24px;
  overflow:hidden;display:flex;flex-direction:column;
  transition:border-color .25s,transform .3s;position:relative;
}
.proj-card:hover{border-color:var(--lime);transform:translateY(-6px)}
.proj-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--lime);transform:scaleX(0);transform-origin:left;
  transition:transform .3s ease;
}
.proj-card:hover::before{transform:scaleX(1)}
.proj-banner{
  padding:1.75rem 1.5rem 1.25rem;
  background:var(--bg2);border-bottom:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:flex-start;
}
.proj-num{
  font-family:'Clash Display',sans-serif;font-size:4rem;font-weight:700;
  color:rgba(200,241,53,0.08);line-height:1;
}
.proj-badge{
  font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--lime-dim);background:rgba(200,241,53,0.08);
  border:1px solid rgba(200,241,53,0.2);border-radius:100px;padding:4px 12px;
  align-self:flex-start;
}
.proj-body{padding:1.5rem;flex:1;display:flex;flex-direction:column;gap:1rem}
.proj-name{
  font-family:'Clash Display',sans-serif;font-size:1.1rem;font-weight:600;
  color:var(--text);line-height:1.25;
}
.proj-desc{font-size:0.84rem;color:var(--muted);line-height:1.7;font-weight:300;flex:1}
.proj-tags{display:flex;flex-wrap:wrap;gap:0.35rem}
.ptag{
  font-size:0.68rem;font-weight:500;color:var(--faint);
  border:1px solid var(--border2);border-radius:100px;padding:2px 9px;
}
.proj-link{
  display:inline-flex;align-items:center;gap:0.5rem;
  font-size:0.82rem;font-weight:600;color:var(--lime);
  text-decoration:none;padding:9px 0;
  border-top:1px solid var(--border);margin-top:auto;
  letter-spacing:0.02em;transition:gap .2s;
}
.proj-link:hover{gap:0.75rem}
.proj-link-arrow{font-size:1rem;transition:transform .2s}
.proj-card:hover .proj-link-arrow{transform:translateX(3px)}

/* FEATURED PROJ */
.proj-card.feat{grid-column:span 2;background:var(--bg3)}
.feat-inner{display:grid;grid-template-columns:1fr 1fr;height:100%}
.feat-left{padding:2rem;border-right:1px solid var(--border);display:flex;flex-direction:column}
.feat-right{padding:2rem;display:flex;flex-direction:column;justify-content:space-between}

/* EDUCATION */
.edu-block{
  background:var(--card);border:1px solid var(--border);border-radius:24px;
  padding:2.5rem;margin-top:4rem;display:grid;grid-template-columns:auto 1fr auto;gap:2rem;align-items:start;
}
.edu-icon{
  width:56px;height:56px;border-radius:14px;background:var(--lime-glow);
  border:1px solid rgba(200,241,53,0.2);display:flex;align-items:center;justify-content:center;
  font-size:24px;flex-shrink:0;
}
.edu-degree{font-family:'Clash Display',sans-serif;font-size:1.5rem;font-weight:700;color:var(--text);margin-bottom:0.3rem;letter-spacing:-0.5px}
.edu-school{font-size:0.9rem;color:var(--lime);font-weight:500;margin-bottom:1rem}
.edu-pills{display:flex;flex-wrap:wrap;gap:0.4rem}
.edu-pill{font-size:0.75rem;color:var(--muted);background:var(--bg2);border:1px solid var(--border2);border-radius:100px;padding:4px 12px}
.edu-year{font-family:'Clash Display',sans-serif;font-size:1rem;color:var(--faint);font-weight:600;white-space:nowrap;align-self:center}

/* GOALS */
.goals-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-top:4rem}
.goal-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem}
.goal-label{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--lime);font-weight:600;margin-bottom:0.75rem}
.goal-title{font-family:'Clash Display',sans-serif;font-size:1.25rem;font-weight:700;color:var(--text);margin-bottom:1rem;letter-spacing:-0.5px}
.goal-items{list-style:none;display:flex;flex-direction:column;gap:0.6rem}
.goal-items li{font-size:0.88rem;color:var(--muted);display:flex;gap:0.75rem;align-items:flex-start}
.goal-items li::before{content:'→';color:var(--lime);flex-shrink:0;font-size:0.85rem}
.goal-big{font-size:1rem;color:var(--muted);line-height:1.75;font-weight:300}

/* CONTACT */
.contact-box{
  background:var(--card);border:1px solid var(--border);border-radius:28px;
  padding:4rem;margin-top:4rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;
}
.contact-heading{font-family:'Clash Display',sans-serif;font-size:clamp(2rem,4vw,4rem);font-weight:700;color:var(--text);letter-spacing:-2px;line-height:1}
.contact-heading em{font-style:normal;color:var(--lime)}
.contact-sub{font-size:0.95rem;color:var(--muted);line-height:1.8;font-weight:300;margin-top:1rem}
.contact-links{display:flex;flex-direction:column;gap:0.75rem}
.c-link{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--bg2);border:1px solid var(--border);border-radius:14px;
  padding:1rem 1.25rem;text-decoration:none;color:var(--text);
  transition:border-color .2s,background .2s;
}
.c-link:hover{border-color:var(--lime);background:var(--bg3)}
.c-link-left{display:flex;align-items:center;gap:0.75rem}
.c-link-icon{width:36px;height:36px;border-radius:8px;background:var(--lime-glow);border:1px solid rgba(200,241,53,0.15);display:flex;align-items:center;justify-content:center;font-size:16px}
.c-link-label{font-size:0.9rem;font-weight:500}
.c-link-sub{font-size:0.75rem;color:var(--faint)}
.c-link-arr{color:var(--faint);font-size:1.1rem;transition:transform .2s,color .2s}
.c-link:hover .c-link-arr{transform:translateX(3px);color:var(--lime)}

/* FOOTER */
footer{
  border-top:1px solid var(--border);padding:2.5rem 3rem;
  display:flex;justify-content:space-between;align-items:center;
  max-width:1300px;margin:0 auto;
}
.footer-text{font-size:0.8rem;color:var(--faint)}
.footer-mark{font-family:'Clash Display',sans-serif;font-size:0.85rem;color:var(--lime);letter-spacing:-0.3px}

/* ANIMATIONS */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.reveal.in{opacity:1;transform:translateY(0)}
.reveal-delay{transition-delay:.15s}
.reveal-delay2{transition-delay:.3s}

@media(max-width:900px){
  nav{padding:0 1.5rem}.nav-links{display:none}
  .hero{padding:5rem 1.5rem 3rem}
  .hero h1{letter-spacing:-2px}
  .hero-bottom{grid-template-columns:1fr;gap:2rem}
  .hero-meta{align-items:flex-start}
  .hero-chips{justify-content:flex-start}
  section{padding:5rem 1.5rem}
  .about-grid,.skills-bento,.proj-grid,.goals-grid{grid-template-columns:1fr}
  .skills-bento .skill-tile.wide{grid-column:span 1}
  .proj-card.feat{grid-column:span 1}
  .feat-inner{grid-template-columns:1fr}
  .feat-right{border-top:1px solid var(--border)}
  .edu-block{grid-template-columns:1fr;gap:1rem}
  .contact-box{grid-template-columns:1fr;gap:2rem;padding:2rem}
  footer{flex-direction:column;gap:0.5rem;text-align:center;padding:2rem 1.5rem}
}
</style>
</head>
